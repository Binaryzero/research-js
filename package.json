{
  "name": "extension-security-analyzer",
  "version": "1.0.0",
  "description": "VS Code extension security analyzer with concurrent LLM processing",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node --max-old-space-size=4096 dist/index.js",
    "cli": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "@fastify/view": "^11.1.1",
    "adm-zip": "^0.5.10",
    "fastify": "^5.8.2",
    "js-yaml": "^4.1.0",
    "nunjucks": "^3.2.4",
    "ollama": "^0.6.3",
    "openai": "^6.33.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/nunjucks": "^3.2.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
