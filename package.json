{
  "name": "extension-security-analyzer",
  "version": "1.0.0",
  "description": "VS Code extension security analyzer with concurrent LLM processing",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node --max-old-space-size=4096 dist/index.js",
    "cli": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.49",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.1.1",
    "@fastify/view": "^11.1.1",
    "@types/nunjucks": "^3.2.6",
    "adm-zip": "^0.5.10",
    "ai": "^6.0.142",
    "eta": "^4.5.1",
    "fastify": "^5.8.5",
    "js-yaml": "^4.1.0",
    "marked": "^17.0.5",
    "nunjucks": "^3.2.4",
    "p-limit": "^7.3.0",
    "pino": "^10.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/js-yaml": "^4.0.9",
    "@types/marked": "^5.0.2",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
