{
  "name": "extension-security-analyzer",
  "version": "1.0.0",
  "description": "VS Code extension security analyzer with concurrent LLM processing",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node --max-old-space-size=4096 dist/index.js",
    "cli": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@fastify/multipart": "^8.3.0",
    "@fastify/static": "^6.12.0",
    "@fastify/view": "^9.0.0",
    "adm-zip": "^0.5.10",
    "dompurify": "^3.0.9",
    "fastify": "^4.26.2",
    "js-yaml": "^4.1.0",
    "marked": "^12.0.1",
    "nunjucks": "^3.2.4",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "undici": "^7.22.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.24",
    "@types/nunjucks": "^3.2.6",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^9.39.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
